# OMDb API keys (optional — scripts ship with built-in defaults)
# Get a key: https://www.omdbapi.com/apikey.aspx
#
# Defaults in scripts/lib/omdb-api-key.*:
#   Primary (Patreon / premium): 68a905c
#   Free fallback: 14e2f0ac (used only if primary fails: invalid, canceled, or quota)
#
# Free: 1,000 requests/day
# Patreon Basic ($1/mo): 100,000 requests/day — https://www.patreon.com/omdb
#
# Override either key below if needed, then run:
#   npm run generate-metadata:ps
OMDB_API_KEY=
OMDB_API_KEY_FREE=
